# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit real secrets.

# --- Core ---
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Use "sqlite" for quick local development (zero setup).
# Use "postgresql" for the school server (matches spec section 6).
DB_ENGINE=sqlite
DB_NAME=digital_library
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend URL (used to build password reset links emailed to users) ---
FRONTEND_URL=http://localhost:5173

# --- Email (password reset) ---
# Default: prints emails to this terminal instead of sending them — perfect
# for local development, no setup needed. For production, switch to:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# and fill in EMAIL_HOST/EMAIL_HOST_USER/EMAIL_HOST_PASSWORD below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Digital Library <no-reply@digitallibrary.local>

# --- Misc ---
TIME_ZONE=Africa/Kampala
MAX_UPLOAD_MB=200

# --- Redis / Celery (Phase 2+: notifications, backups, sync) ---
REDIS_URL=redis://localhost:6379/0

# --- Storage monitoring ---
STORAGE_WARNING_THRESHOLD_PERCENT=85
